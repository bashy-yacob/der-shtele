# ============================================================
# .env.example — תבנית בטוחה לשיתוף (ללא ערכים אמיתיים)
# העתיקו לקבצים המתאימים ומלאו ערכים:
#   - backend/.env       (סודות שרת — SERVICE_ROLE_KEY, DATABASE_URL, JWT_SECRET)
#   - frontend/.env.local (מפתחות צד לקוח — NEXT_PUBLIC_*)
# ============================================================

# ---------- Backend (NestJS) ----------

# שרת
PORT=4000
NODE_ENV=development
# מאיפה מותר לקרוא ל-API (CORS) — דומיין ה-frontend
FRONTEND_ORIGIN=http://localhost:3000

# Database (PostgreSQL + Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/dershtele?schema=public
DIRECT_URL=postgresql://user:password@localhost:5432/dershtele?schema=public

# Supabase Storage (bucket פרטי לקורות חיים)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_RESUME_BUCKET=resumes

# Auth (שלב ב)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# מייל הצוות — לאן מגיעות פניות מהאתר
TEAM_EMAIL=info@dershtele.co.il

# SMTP / Resend לשליחת מיילים
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
# RESEND_API_KEY=re_xxx

# ---------- Frontend (Next.js) ----------

# כתובת ה-backend שאליה ה-frontend פונה (server-side)
BACKEND_API_URL=http://localhost:4000
# כתובת ציבורית ל-client (אם נדרש fetch מהדפדפן)
NEXT_PUBLIC_API_URL=http://localhost:4000

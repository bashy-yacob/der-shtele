{
  "name": "der-shtele",
  "version": "0.1.0",
  "private": true,
  "description": "דער שטעלע — סוכנות השמה דיגיטלית לציבור החרדי. Monorepo: frontend (Next.js) + backend (NestJS).",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run start:dev --workspace backend",
    "build": "npm run build --workspaces --if-present",
    "build:frontend": "npm run build --workspace frontend",
    "build:backend": "npm run build --workspace backend",
    "lint": "npm run lint --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "prisma:seed": "npm run prisma:seed --workspace backend"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}

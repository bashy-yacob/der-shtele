// ============================================================
// Prisma Schema — דער שטעלע
// DB: PostgreSQL
// שלב א: candidates, jobs (public)
// שלב ב: employers, job_presentations, call_logs
// שלב ג: placements, commissions, reminders
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------
// Enums — מקביל ל-src/types/index.ts
// ----------------------------------------------------------------

enum JobField {
  logistics
  admin
  sales
  education
  tech
  finance
  healthcare
  other
}

// אזור/עיר — טקסט חופשי (לא enum). מאפשר הוספת ערים חדשות אוטומטית
// בעת יצירת משרה/מועמד. רשימת הברירה נגזרת מהערכים הקיימים ב-DB.

enum JobStatus {
  pending // ממתינה לאישור הצוות (משרה שמעסיק פרסם דרך הפורטל)
  active
  paused
  closed
  filled
}

enum CandidateStatus {
  new
  in_progress
  presented
  hired
  not_suitable
}

enum PlacementStatus {
  pending
  confirmed
  guarantee
  completed
  cancelled
}

enum CommissionStatus {
  not_due        // טרם לגבייה — בתוך תקופת הערבות (ברירת מחדל בגיוס)
  due            // לגבייה — הערבות הסתיימה בהצלחה
  invoiced       // נשלחה חשבונית
  paid           // שולם
  partial_refund // החזר חלקי (ביטול בתוך ערבות)
}

// סוגי פעולות בלוג הגיוס (placement_events) — היסטוריה מלאה לכל גיוס
enum PlacementEventType {
  created             // הגיוס נוצר (סימון "גויס")
  confirmed           // הגיוס אושר
  guarantee           // נכנס לתקופת ערבות
  completed           // הגיוס הושלם (ערבות עברה)
  cancelled           // הגיוס בוטל
  commission_due      // העמלה נכנסה לגבייה (תום ערבות)
  commission_invoiced // נשלחה חשבונית
  commission_paid     // העמלה שולמה
  commission_refunded // החזר חלקי למעסיק
  amount_updated      // סכום העמלה עודכן
}

enum UserRole {
  candidate    // מועמד — אזור אישי
  employer     // מעסיק — פורטל ייעודי (משויך ל-Employer)
  staff        // נציג צוות — CRM
  admin        // מנהל מערכת
}

// מצב אישור מעסיק — תומך בהרשמה עצמית כ"בקשת גישה" (סעיף 6).
enum EmployerStatus {
  pending   // נרשם עצמאית — ממתין לאישור הצוות; לא יכול לפרסם
  approved  // אושר ע"י הצוות (או נוצר ידנית ע"י הצוות / מעסיק ותיק)
  rejected  // נדחה
}

// אופן ההזדהות של המשתמש — אימייל+סיסמה מקומי או חשבון Google
enum AuthProvider {
  local
  google
}

// ----------------------------------------------------------------
// שלב ד — פרסומות בתשלום (באנרי חסות + משרות ממומנות)
// ----------------------------------------------------------------

// מיקום הצגת מודעת חסות באתר
enum AdPlacement {
  homepage  // פס חסות בדף הבית
  jobs_list // אזור בלוח המשרות
  footer    // כותרת תחתונה
}

// מחזור חיים של מודעה — מוצגת רק כש-active (וגם paid + בתוך חלון תאריכים)
enum AdStatus {
  draft           // טיוטה — לא מוצגת
  pending_payment // אושר תוכן, ממתין לתשלום
  active          // משולם + מאושר — מועמד להצגה
  paused          // הושהה ידנית
  expired         // עבר endDate
}

// סטטוס תשלום — נאכף כשער prepaid (גם למודעות וגם למשרות ממומנות)
enum AdPaymentStatus {
  unpaid
  paid
}

// ----------------------------------------------------------------
// שלב ב — משתמשים (auth)
// ----------------------------------------------------------------

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  // nullable — משתמשי Google נוצרים בלי סיסמה מקומית
  passwordHash   String?
  fullName       String
  role           UserRole   @default(candidate)

  // הזדהות חיצונית (Google OAuth)
  authProvider   AuthProvider @default(local)
  googleId       String?      @unique // ה-"sub" של Google — מזהה יציב
  profilePicture String?      // נשמר אך לא מוצג (כלל "ללא תמונות אנשים")

  // אימות כתובת מייל (סעיף 3.1). משתמשי Google מאומתים אוטומטית.
  emailVerified      Boolean   @default(false)
  verificationToken  String?   @unique // טוקן חד-פעמי לאימות; null אחרי אימות
  verificationSentAt DateTime?

  // opt-in חובה בהרשמה — הסכמה לקבלת עדכונים
  optInMarketing Boolean    @default(false)
  optInAt        DateTime?
  // מתי הוצגה לאחרונה תזכורת ה-opt-in (תזכורת חודשית למשתמשי Google שלא אישרו)
  optInPromptedAt DateTime?

  // פרטי פרופיל לדיוור מותאם אישית — המשתמש ממלא מרצון באזור האישי.
  // עיר/תחום מפלחים את רשימת התפוצה; טלפון/ניסיון משרתים את הצוות.
  phone           String?
  city            String?   // עיר/אזור מגורים — פילוח דיוור לפי אזור (region)
  preferredField  JobField? // תחום תעסוקה מבוקש — פילוח דיוור לפי תחום (field)
  yearsExperience Int?      // שנות ניסיון — סינון פנימי של הצוות

  // קישור לרשומת מועמד ב-CRM (אם זה מועמד)
  candidateId    String?    @unique
  candidate      Candidate? @relation(fields: [candidateId], references: [id])

  // קישור למעסיק (אם זה משתמש פורטל מעסיקים, role=employer)
  employerId     String?
  employer       Employer?  @relation(fields: [employerId], references: [id], onDelete: SetNull)

  // משרות שהמשתמש שמר ללב — להגשה מאוחר יותר
  savedJobs      SavedJob[]

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("users")
}

// ----------------------------------------------------------------
// שלב ב — מעסיקים (פנימי לחלוטין)
// ----------------------------------------------------------------

model Employer {
  id             String   @id @default(cuid())
  companyName    String
  businessNumber String?  // ח.פ
  address        String?
  contactName    String
  contactPhone   String
  contactEmail   String
  notes          String?  // אמינות, העדפות

  // אישור גישה (סעיף 6). ברירת מחדל approved — מעסיק שהצוות יוצר ידנית מאושר
  // אוטומטית; רק הרשמה עצמית כופה pending. כך גם backfill של שורות קיימות.
  status          EmployerStatus @default(approved)
  approvedAt      DateTime?
  rejectionReason String?

  jobs           Job[]
  placements     Placement[]
  portalUsers    User[]   // משתמשי פורטל המשויכים למעסיק הזה (role=employer)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@map("employers")
}

model Contact {
  id           String   @id @default(cuid())
  name         String
  phone        String
  inquiry_type String
  message      String
  resumePath   String?  // New field for resume file path

  // פרטים מובְנים מטופס פניית מעסיק — null לפניות מועמד/כללי.
  // נשמרים מובְנה (ולא כטקסט חופשי ב-message) כדי שהצוות יקבל בדשבורד את כל
  // מה שצריך לפתיחת משרה, בלי לרדוף אחרי פרטים ובלי פענוח regex שביר.
  email           String?   // מייל איש הקשר
  companyName     String?   // שם החברה
  businessNumber  String?   // ח.פ / מספר עוסק
  companyLocation String?   // מיקום החברה / כתובת
  jobTitle        String?   // שם התפקיד המבוקש
  field           JobField? // תחום
  region          String?   // עיר/אזור
  scope           String?   // היקף — 'מלאה' | 'חלקית' | 'גמיש'
  experience      String?   // ניסיון נדרש
  salary          String?   // טווח שכר מוצע — פנימי בלבד

  // מעקב טיפול הצוות — null = טרם טופל; מסומן = טופל (חותמת הזמן בה סומן).
  handledAt    DateTime?

  // הסכמה לקבלת עדכונים/תוכן שיווקי (חוק הספאם) — אופציונלי בטופס צור-קשר.
  // optInAt נשמר רק אם המשתמש סימן הסכמה (תאריך + שעה — חובה לפי החוק).
  optInMarketing Boolean   @default(false)
  optInAt        DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("contacts")
}

// ----------------------------------------------------------------
// שלב א+ב — משרות
// ----------------------------------------------------------------

model Job {
  id                    String    @id @default(cuid())
  employerId            String
  employer              Employer  @relation(fields: [employerId], references: [id])

  title                 String
  descriptionPublic     String    // מה שעולה לאתר — אנונימי
  descriptionInternal   String    // דרישות מלאות — פנימי בלבד

  field                 JobField
  region                String    // עיר/אזור — טקסט חופשי
  scope                 String    // 'מלאה' | 'חלקית' | 'גמיש'

  experience            String?   // ניסיון נדרש — גלוי לציבור (כרטיס/דף/סינון)
  salary                String?   // שכר מוצע — פנימי בלבד, לא עולה לאתר

  status                JobStatus @default(active)
  openedAt              DateTime  @default(now())
  closedAt              DateTime?

  // קידום משרה בתשלום (Featured) — שער תשלום-מראש כמו עמלות. המשרה עולה לראש
  // הלוח רק כש-featuredPaymentStatus=paid וגם now <= featuredUntil.
  featuredUntil         DateTime?
  featuredPaymentStatus AdPaymentStatus @default(unpaid)
  featuredPaidAt        DateTime?
  featuredPrice         Float?    // מחיר מוסכם — פנימי

  presentations         JobPresentation[]
  placements            Placement[]
  savedBy               SavedJob[]

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("jobs")
}

// ----------------------------------------------------------------
// שלב ב — משרות שמורות (מועמד שומר ♡ משרה להגשה מאוחר יותר)
// ----------------------------------------------------------------

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, jobId]) // משרה נשמרת פעם אחת בלבד לכל משתמש
  @@map("saved_jobs")
}

// ----------------------------------------------------------------
// שלב א+ב — מועמדים
// ----------------------------------------------------------------

model Candidate {
  id           String          @id @default(cuid())
  fullName     String
  phone        String
  email        String
  city         String          @default("")
  field        JobField
  region       String          // עיר/אזור — טקסט חופשי
  birthYear    Int?            // שנת לידה (אופציונלי) — נמסר בהגשה למשרה ספציפית

  cvUrl        String?         // Supabase Storage URL
  cvUploadedAt DateTime?

  status       CandidateStatus @default(new)
  notes        String?         // הערות פנימיות

  callLogs     CallLog[]
  presentations JobPresentation[]
  placements   Placement[]
  reminders    Reminder[]
  user         User?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // אינדקסים לסינון ה-CRM/דיוור לפי תחום/אזור/סטטוס (DAT-2).
  @@index([field])
  @@index([region])
  @@index([status])
  @@map("candidates")
}

// ----------------------------------------------------------------
// שלב ב — היסטוריית שיחות
// ----------------------------------------------------------------

model CallLog {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  staffName   String    // מי מהצוות
  calledAt    DateTime  @default(now())
  summary     String
  followUpAt  DateTime? // תזכורת לשיחה חוזרת

  @@map("call_logs")
}

// ----------------------------------------------------------------
// שלב ב — הצגת מועמד למשרה
// ----------------------------------------------------------------

model JobPresentation {
  id          String          @id @default(cuid())
  jobId       String
  job         Job             @relation(fields: [jobId], references: [id])
  candidateId String
  candidate   Candidate       @relation(fields: [candidateId], references: [id])

  presentedAt DateTime        @default(now())
  status      CandidateStatus @default(presented) // סטטוס ביחס למשרה הספציפית
  notes       String?

  @@unique([jobId, candidateId]) // מועמד לא יוצג פעמיים לאותה משרה
  @@map("job_presentations")
}

// ----------------------------------------------------------------
// שלב ג — גיוס מוצלח
// ----------------------------------------------------------------

model Placement {
  id               String          @id @default(cuid())
  jobId            String
  job              Job             @relation(fields: [jobId], references: [id])
  candidateId      String
  candidate        Candidate       @relation(fields: [candidateId], references: [id])
  employerId       String
  employer         Employer        @relation(fields: [employerId], references: [id])

  placedAt         DateTime        @default(now())
  guaranteeEndsAt  DateTime        // placedAt + 3 חודשים — מחושב ב-statusMachine
  status           PlacementStatus @default(pending)

  commissionAmount Float?          // בשקלים
  commissionStatus CommissionStatus @default(not_due)

  notes            String?

  events           PlacementEvent[]

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("placements")
}

// ----------------------------------------------------------------
// שלב ג — לוג פעולות לגיוס (היסטוריה אמיתית עם חותמת זמן)
// כל פעולה על גיוס/עמלה נרשמת כאן — כדי שהצוות יראה את כל השרשרת
// ולא "תקפוץ" עמלה פתאום אחרי תקופה.
// ----------------------------------------------------------------

model PlacementEvent {
  id          String             @id @default(cuid())
  placementId String
  placement   Placement          @relation(fields: [placementId], references: [id], onDelete: Cascade)

  type        PlacementEventType
  note        String?            // פירוט אנושי (סכום, מעבר סטטוס)
  createdBy   String?            // שם הנציג שביצע

  createdAt   DateTime           @default(now())

  @@index([placementId])
  @@map("placement_events")
}

// ----------------------------------------------------------------
// שלב ג — תזכורות לצוות
// ----------------------------------------------------------------

model Reminder {
  id          String    @id @default(cuid())
  candidateId String?
  candidate   Candidate? @relation(fields: [candidateId], references: [id])
  jobId       String?   // אפשר לקשר לתזכורת גם ללא מועמד ספציפי

  message     String
  remindAt    DateTime
  done        Boolean   @default(false)
  createdBy   String    // שם נציג

  createdAt   DateTime  @default(now())

  @@map("reminders")
}

// ----------------------------------------------------------------
// המלצות לקוחות — מוצגות בדף הבית (קרוסלה), מנוהלות מהדשבורד.
// צניעות ופרטיות: authorName הוא שם פרטי / ראשי תיבות בלבד — לא שם מלא;
// אין שדה תמונה (כלל "ללא תמונות אנשים").
// ----------------------------------------------------------------

model Testimonial {
  id          String   @id @default(cuid())
  authorName  String   // שם פרטי / ראשי תיבות (למשל "י.כ.")
  authorRole  String?  // תיאור / הקשר ("מועמד שהושם", "מנהל גיוס בבני ברק")
  quote       String   // גוף ההמלצה
  published   Boolean  @default(true) // האם מוצגת באתר הציבורי
  order       Int      @default(0)    // סדר תצוגה — עולה (קטן קודם)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("testimonials")
}

// ----------------------------------------------------------------
// שלב ד — מודעות חסות בתשלום (מנוהלות מהדשבורד, מוצגות באתר הציבורי)
// תשלום מראש (prepaid): מודעה מוצגת רק כש-status=active + paymentStatus=paid
// ובתוך חלון התאריכים. כלל ברזל: ללא תמונות אנשים; כל מודעה מאושרת ע"י הצוות.
// פרטי המפרסם (שם/טלפון/מייל/מחיר) הם פנימיים — לעולם לא בתגובה הציבורית.
// ----------------------------------------------------------------

model Advertisement {
  id             String          @id @default(cuid())

  // --- מפרסם (שדות שטוחים — אין מודל Advertiser נפרד ב-MVP) ---
  advertiserName String          // שם המפרסם (עסק / אדם) — פנימי
  contactPhone   String          // פנימי — גבייה/יצירת קשר
  contactEmail   String?         // פנימי

  // --- תוכן המודעה ---
  title          String
  body           String?         // טקסט קצר — ללא הבטחות מטעות
  imagePath      String?         // נתיב ב-bucket ציבורי 'ads' (לא URL). ללא תמונות אנשים.
  linkUrl        String?         // יעד בלחיצה (אופציונלי)

  // --- מיקום ותצוגה ---
  placement      AdPlacement
  order          Int             @default(0) // סדר בתוך אותו placement (קטן קודם)

  // --- מחזור חיים + שער תשלום-מראש ---
  status         AdStatus        @default(draft)
  paymentStatus  AdPaymentStatus @default(unpaid)
  paidAt         DateTime?
  agreedPrice    Float?          // מחיר מוסכם בש"ח — פנימי

  startDate      DateTime?       // null = מתחיל מיד עם הפעלה
  endDate        DateTime?       // null = ללא תפוגה

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([placement, status])
  @@map("advertisements")
}

// ----------------------------------------------------------------
// שותפים — לוגואים של חנויות/מעסיקים שהסכימו להופיע ("עם מי אנחנו עובדים").
// מוצגים כרשת לוגואים באתר הציבורי, מנוהלים מהדשבורד. מוסיפים אחד-אחד ככל
// שמעסיק מסכים ושולח לוגו. צניעות: לוגו בלבד — ללא תמונות אנשים/פנים.
// ----------------------------------------------------------------

model Partner {
  id           String   @id @default(cuid())
  partnerName  String   // שם החנות/המעסיק — מוצג כ-alt וכ-tooltip
  logoPath     String   // נתיב ב-bucket ציבורי 'partners' (לא URL). ללא תמונות אנשים.
  linkUrl      String?  // יעד בלחיצה (אופציונלי — אתר החנות)
  displayOrder Int      @default(0) // סדר תצוגה — עולה (קטן קודם)
  isActive     Boolean  @default(true) // האם מוצג באתר הציבורי

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, displayOrder])
  @@map("partners")
}

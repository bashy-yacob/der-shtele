# דער שטעלע — backend/.env (דוגמה)
# ----------------------------------------------------------------
# העתק קובץ זה ל-backend/.env ומלא ערכים אמיתיים. אל תכניס סודות אמיתיים
# לקובץ הדוגמה הזה — הוא נכנס ל-git. את backend/.env עצמו git מתעלם ממנו.

# --- בסיס נתונים (Supabase) ---
DATABASE_URL=postgresql://...        # מחרוזת החיבור (pooler, פורט 6543)

# --- אבטחה ---
JWT_SECRET=                          # חובה. השרת לא יעלה בלעדיו.
JWT_EXPIRES_IN=7d

# --- פרונט ---
FRONTEND_ORIGIN=http://localhost:3000

# --- אחסון קו"ח (Supabase Storage) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_RESUME_BUCKET=resumes
# bucket ציבורי לתמונות באנרי פרסומות. ליצור ב-Supabase כ-PUBLIC (שונה מ-resumes).
SUPABASE_ADS_BUCKET=ads

# ================================================================
# מיילים (Resend דרך SMTP)
# ================================================================
# מה צריך:
#   1. להירשם ב-https://resend.com וליצור API key (מתחיל ב-re_...).
#   2. בבדיקה: אפשר לשלוח רק מ-onboarding@resend.dev ורק לכתובת שאיתה
#      נרשמת ל-Resend. כדי לשלוח מ-@dershtele.co.il לכל כתובת — לאמת את
#      הדומיין dershtele.co.il ב-Resend (הוספת רשומות DNS) ואז להחליף את
#      MAIL_FROM ל-noreply@dershtele.co.il.
#
# שים לב: ב-Resend שם המשתמש ל-SMTP הוא המחרוזת הקבועה 'resend',
# וה-API key נכנס כסיסמה. כתובת השולח (MAIL_FROM) נפרדת משם המשתמש.

SMTP_HOST=smtp.resend.com
SMTP_PORT=587                        # 587 (STARTTLS) או 465 (TLS מיידי)
SMTP_USER=resend                     # קבוע ב-Resend. ב-Gmail: כתובת המייל.
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx     # ה-API key של Resend (או App Password ב-Gmail)
MAIL_FROM=onboarding@resend.dev      # כתובת השולח. אחרי אימות דומיין: noreply@dershtele.co.il
MAIL_FROM_NAME=דער שטעלע             # שם תצוגה (אופציונלי)
TEAM_EMAIL=dershtele@gmail.com       # לאן נשלחות התראות הצוות

# הערה: כל עוד SMTP_PASS ריק — שליחת המיילים במצב fail-soft (רק log, לא נשלח).

# --- seed ---
SEED_ADMIN_PASSWORD=                 # סיסמת ה-admin הראשוני (אל תשתמש בחלשה)
